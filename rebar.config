{deps, [
    certifi,
    {getopt, "1.0.2"},
    %% Can't use the hex version because rebar3 pulls in its optional Elixir only
    %% dependency
    {purl, {git, "git@github.com:erlef/purl.git", {tag, "v0.3.0"}}}
]}.

{erl_opts, [
    debug_info,
    {i, "src/include"},
    warnings_as_errors,
    warn_export_vars,
    warn_unused_import,
    warn_keywords
]}.

{escript_name, rebar3_dependency_submission}.
{escript_emu_args,
    "%%! +pc unicode -escript main rebar3_dependency_submission\n"}.

{project_plugins, [
    {rebar3_ex_doc, "0.2.30"},
    {erlfmt, "1.7.0"}
]}.

{erlfmt, [
    write,
    {print_width, 80},
    {files, [
        "*.config{,.script}",
        "src/**/*.{hrl,app.src,erl}",
        "test/**/*.erl"
    ]}
]}.

{alias, [
    {ci, [
        {do, "fmt --check"},
        xref,
        dialyzer,
        eunit,
        ct,
        ex_doc,
        cover,
        escriptize
    ]}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    incremental,
    {warnings, [unmatched_returns]}
]}.
{profiles, [
    {test, [
        {cover_enabled, true},
        {cover_opts, [verbose]}
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    % TBD(erlef): update source_url
    {source_url, "https://github.com/kivra/rebar3-dependency-submission"},
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"LICENSE.md", #{title => "License"}}
    ]},
    {main, "README.md"}
]}.
