{application, rebar3_dependency_submission, [
    {description,
        "Calculates dependencies for Rebar3 and submits the list to the GitHub Dependency Submission API"},
    % release-TAG
    {vsn, "v1.0.0-beta.3"},
    {applications, [
        kernel,
        stdlib,
        inets,
        ssl,
        certifi,
        getopt,
        purl
    ]},
    {licenses, ["Apache-2.0"]}
]}.
