{application, rebar_dependency_submission, [
    {description,
        "Calculates dependencies for rebar3 and submits the list to the GitHub Dependency Submission API"},
    {vsn, semver},
    {applications, [
        kernel,
        stdlib,
        inets,
        ssl,
        certifi,
        getopt,
        purl
    ]},
    {licenses, ["Apache-2.0"]}
]}.
